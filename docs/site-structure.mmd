flowchart TB
  subgraph site["Сайт — гости и пациенты (единая структура)"]
    direction TB
    ROOT["/ — главная, навигация по разделам, запись на приём и т.п."]

    ROOT --> CONTACTS["/contacts — контакты, карта, реквизиты"]

    ROOT --> SVC["/services — каталог услуг"]
    SVC --> SVC_CAT["/services/[categorySlug] — услуги категории"]
    SVC_CAT --> SVC_ID["/services/[categorySlug]/[serviceId] — карточка услуги, запись"]

    ROOT --> DOC["/doctors — каталог специалистов"]
    DOC --> DOC_ID["/doctors/[categorySlug]/[doctorId] — карточка врача, запись"]
    DOC --> DOC_CATCH["/doctors/[...slug] — вспомогательные маршруты раздела врачей"]

    ROOT --> CLINIC["/clinic — о клинике, материалы и вложенные страницы"]
    CLINIC --> CLINIC_SLUG["/clinic/[...slug] — статьи, подразделы клиники"]

    ROOT --> FAQ["/clinic/questions — вопросы и ответы"]
    FAQ --> FAQ_SLUG["/clinic/questions/[slug] — категория или тема FAQ"]

    ROOT --> ACC["/account — личный кабинет пациента"]
    ACC --> ACC_SUB["/account/[...slug] — профиль, записи, письма главврачу, чаты с оператором и др. подразделы ЛК"]

    ROOT --> PAT["/patient — сценарий пациента (по реализации UI)"]
  end

  subgraph adm["Только админ-панель (отдельно)"]
