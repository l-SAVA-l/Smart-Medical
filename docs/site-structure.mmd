    AD --> AD_LET["/admin/letters — письма главному врачу"]
    AD --> AD_FB["/admin/feedbacks — отзывы"]
    AD --> AD_SVC["/admin/services — услуги"]
    AD --> AD_SVCAT["/admin/service-categories — категории услуг"]
    AD --> AD_Q["/admin/questions — вопросы FAQ"]
    AD --> AD_QCAT["/admin/question-categories — категории вопросов"]
    AD --> AD_MAT["/admin/materials — материалы / новости"]
    AD --> AD_VAC["/admin/vacancies — вакансии"]
    AD --> AD_PAR["/admin/partners — партнёры"]
    AD --> AD_CON["/admin/contacts — контакты на сайте"]
    AD --> AD_USR["/admin/users — пользователи / блокировки"]
