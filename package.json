{
  "name": "smartmedical",
  "version": "0.1.0",
  "private": true,
  "prisma": {
    "seed": "tsx prisma/seeds.ts"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "prisma:migrate": "npx dotenv-cli -e .env -- npx prisma migrate deploy",
    "prisma:migrate:dev": "npx dotenv-cli -e .env -- npx prisma migrate dev",
    "prisma:generate": "npx dotenv-cli -e .env -- npx prisma generate",
    "prisma:studio": "npx dotenv-cli -e .env -- npx prisma studio",
    "prisma:seed": "npx dotenv-cli -e .env -- npx prisma db seed",
    "prisma:seed:partners": "npx dotenv-cli -e .env -- npx tsx prisma/seed-partner-categories.ts",
    "prisma:reset": "npx dotenv-cli -e .env -- npx prisma migrate reset",
    "prisma:push": "npx dotenv-cli -e .env -- npx prisma db push",
    "prisma:backfill:service-categories": "npx dotenv-cli -e .env -- npx tsx scripts/backfill-service-category-id.ts --apply",
    "prisma:backfill:service-categories:dry": "npx dotenv-cli -e .env -- npx tsx scripts/backfill-service-category-id.ts",
    "prisma:normalize:new-structure": "npx dotenv-cli -e .env -- npx tsx scripts/normalize-db-new-structure.ts --apply",
    "prisma:normalize:new-structure:dry": "npx dotenv-cli -e .env -- npx tsx scripts/normalize-db-new-structure.ts",
    "upload:cloudinary": "npx dotenv-cli -e .env -- npx tsx scripts/upload-to-cloudinary.ts",
    "setup": "npm run prisma:migrate && npm run prisma:generate && npm run prisma:normalize:new-structure"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.4",
    "@mui/material": "^7.3.4",
    "@next/swc-win32-x64-msvc": "^16.1.6",
    "@prisma/client": "^6.18.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "cloudinary": "^2.8.0",
    "framer-motion": "^12.23.24",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.548.0",
    "next": "16.0.0",
    "next-auth": "^4.24.13",
    "next-cloudinary": "^6.17.5",
    "nodemailer": "^7.0.13",
    "prisma": "^6.18.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "baseline-browser-mapping": "^2.10.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.0.0",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5"
  }
}
